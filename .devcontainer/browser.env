PUID=1000
PGID=1000
TZ=Asia/Shanghai
CUSTOM_PORT=3100
CUSTOM_HTTPS_PORT=3101
TITLE=Harness Kanban Workspace Browser
# Basic auth is recommended because the GUI grants shell access inside the browser container.
